	(text "Carry in is active-low, matrix in is active high,\nfinal output to the accumulator is active low.\nThis is effectively OR'ing carry in and matrix in.\n\n~{OUT_ACCUM} = (NOT ~{CARRY_IN}) NOR MATRIX_IN"
		(exclude_from_sim no)
		(at 167.132 93.218 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00b4eea9-23e0-4b0c-89e6-971a0e75e67c")
	)
	(text "1. All resistors 1/2 watt unless otherwise stated.\n2. All capacitors in MMFD (pF), 500 V.D.C.\n3. Tube unit location: G1,H1,J1,L1,M1,N1,R1,S1,T1,U1,X1,Y1,Z1."
		(exclude_from_sim no)
		(at 32.004 178.816 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "09275352-32c3-48bb-a21d-a5e7c1f3ae30")
	)
